generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ConversationTurn {
  id        String   @id @default(cuid())
  phone     String
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}
