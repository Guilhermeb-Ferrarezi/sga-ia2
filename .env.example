API_PORT=5000
HOST_API_PORT=5000
API_BASE_PATH=/api
APP_NAME=WhatsApp-AI-Bot

WEBHOOK_VERIFY_TOKEN=change-me
WHATSAPP_TOKEN=change-me
WHATSAPP_PHONE_NUMBER_ID=change-me
WHATSAPP_GRAPH_VERSION=v21.0

OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
ASSISTANT_LANGUAGE=pt-BR
ASSISTANT_PERSONALITY=amigavel, profissional e confiante em esports
ASSISTANT_STYLE=respostas curtas, objetivas e orientadas a acao
ASSISTANT_SYSTEM_PROMPT=
REPLY_DELAY_PER_CHAR_MS=35
REPLY_DELAY_MIN_MS=700
REPLY_DELAY_MAX_MS=7000

ENABLE_DB=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_ai
